<Window x:Class="IMVUCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="IMVU Companion v0.9.0"
        Icon="icon.ico"
        MinHeight="640" MinWidth="960" Height="820" Width="1180"
        WindowStyle="SingleBorderWindow"
        Background="#1A1A2E"
        Topmost="False"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <!-- Thin scrollbars (no bulky up/down buttons) — Windows Terminal / modern PS style -->
        <SolidColorBrush x:Key="ScrollTrackBrush" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#4A4A6A"/>
        <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#6A6A90"/>
        <SolidColorBrush x:Key="ScrollThumbPressedBrush" Color="#8080B0"/>

        <Style x:Key="ThinScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd" Background="{StaticResource ScrollThumbBrush}"
                                CornerRadius="4" Margin="1" SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ScrollThumbHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ScrollThumbPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="Transparent" Width="8">
                <Border Background="{StaticResource ScrollTrackBrush}" CornerRadius="4" Margin="1,0"/>
                <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ThinScrollBarThumb}" MinHeight="28"/>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="Transparent" Height="8">
                <Border Background="{StaticResource ScrollTrackBrush}" CornerRadius="4" Margin="0,1"/>
                <Track x:Name="PART_Track" Focusable="False">
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ThinScrollBarThumb}" MinWidth="28"/>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="MinWidth" Value="8"/>
                    <Setter Property="Height" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="MinHeight" Value="8"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"
                                                    Margin="{TemplateBinding Padding}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1" Grid.Row="0"
                                       Orientation="Vertical"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar" Grid.Column="0" Grid.Row="1"
                                       Orientation="Horizontal"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Win11Button" TargetType="Button">
            <Setter Property="Background" Value="#1E1E32"/>
            <Setter Property="Foreground" Value="#E8E8FF"/>
            <Setter Property="BorderBrush" Value="#3A3A58"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2C2C48"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5050A0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#161628"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Win11ButtonAccent" TargetType="Button" BasedOn="{StaticResource Win11Button}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6"/>
        </Style>
        <Style x:Key="Win11BotToggleButton" TargetType="Button" BasedOn="{StaticResource Win11ButtonAccent}">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="GlowRing" CornerRadius="6" BorderThickness="2"
                                    Background="Transparent" Visibility="Collapsed" IsHitTestVisible="False"
                                    Panel.ZIndex="0">
                                <Border.BorderBrush>
                                    <LinearGradientBrush SpreadMethod="Repeat" StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FFFFFF" Offset="0"/>
                                        <GradientStop Color="#1A1A2E" Offset="0.22"/>
                                        <GradientStop Color="#C8C8FF" Offset="0.5"/>
                                        <GradientStop Color="#1A1A2E" Offset="0.78"/>
                                        <GradientStop Color="#FFFFFF" Offset="1"/>
                                        <LinearGradientBrush.RelativeTransform>
                                            <RotateTransform x:Name="BotGlowRotate" CenterX="0.5" CenterY="0.5"/>
                                        </LinearGradientBrush.RelativeTransform>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                            </Border>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}" Margin="2"
                                    Panel.ZIndex="1" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2C2C48"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5050A0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#161628"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Win11ButtonSmall" TargetType="Button" BasedOn="{StaticResource Win11Button}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource Win11Button}"/>

        <!-- Single-line inputs: left padding + vertically centered text -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#141428"/>
            <Setter Property="Foreground" Value="#E0E0FF"/>
            <Setter Property="BorderBrush" Value="#3A3A58"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#E8E8FF"/>
            <Setter Property="SelectionBrush" Value="#5050A0"/>
            <Setter Property="FontSize" Value="11"/>
            <!-- ~one character of inset; keep text near the left edge -->
            <Setter Property="Padding" Value="3,0,3,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          VerticalAlignment="Center"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5050A0"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7070C0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared dark dropdown palette -->
        <SolidColorBrush x:Key="Win11ComboBg" Color="#1E1E32"/>
        <SolidColorBrush x:Key="Win11ComboFg" Color="#E8E8FF"/>
        <SolidColorBrush x:Key="Win11ComboBorder" Color="#3A3A58"/>
        <SolidColorBrush x:Key="Win11ComboHover" Color="#2C2C48"/>
        <SolidColorBrush x:Key="Win11ComboSelected" Color="#353560"/>
        <SolidColorBrush x:Key="Win11ComboPopupBg" Color="#1A1A2E"/>

        <Style x:Key="Win11ComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Win11ComboFg}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Win11ComboHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Win11ComboSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="Win11ComboBoxToggleButtonTemplate" TargetType="ToggleButton">
            <Border x:Name="Bd" Background="Transparent" SnapsToDevicePixels="True"/>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Win11ComboHover}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Win11ComboSelected}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="Win11ComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource Win11ComboFg}"/>
            <Setter Property="Background" Value="{StaticResource Win11ComboBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Win11ComboBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource Win11ComboBoxItem}"/>
            <Setter Property="MaxDropDownHeight" Value="240"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource Win11ComboBoxToggleButtonTemplate}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" IsHitTestVisible="False"/>
                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="ContentSite" Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Left" VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  IsHitTestVisible="False"/>
                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="#A0A0C8" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Width="8" Height="5" Stretch="Fill" IsHitTestVisible="False"/>
                            </Grid>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True"
                                   Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Focusable="False" PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder"
                                        Background="{StaticResource Win11ComboPopupBg}"
                                        BorderBrush="{StaticResource Win11ComboBorder}"
                                        BorderThickness="1" CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,2,0,0" Padding="2">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#5050A0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- File Explorer–style: looks like a toolbar button, opens a menu below -->
        <Style x:Key="Win11ComboBoxButton" TargetType="ComboBox" BasedOn="{StaticResource Win11ComboBox}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource Win11ComboBoxToggleButtonTemplate}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource Win11ComboBorder}"
                                    BorderThickness="1" CornerRadius="6" IsHitTestVisible="False"/>
                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="18"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="ContentSite" Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Left" VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  IsHitTestVisible="False"/>
                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="#A0A0C8" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Width="8" Height="5" Stretch="Fill" IsHitTestVisible="False"/>
                            </Grid>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True"
                                   Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Focusable="False" PopupAnimation="Fade">
                                <Border Background="{StaticResource Win11ComboPopupBg}"
                                        BorderBrush="{StaticResource Win11ComboBorder}"
                                        BorderThickness="1" CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,2,0,0" Padding="2">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Win11ComboHover}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#5050A0"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Win11ComboSelected}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#5050A0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource Win11ComboBox}"/>

    </Window.Resources>
    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="MainLeftCol" Width="2.2*" MinWidth="420"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition x:Name="MainRightCol" Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left: embedded IMVU -->
        <Border Grid.Column="0" Background="#12121F" CornerRadius="6" BorderBrush="#2A2A45" BorderThickness="1">
            <DockPanel Margin="4">
                <Border DockPanel.Dock="Top" Background="#252540" CornerRadius="4" Padding="6,4" Margin="0,0,0,4">
                    <DockPanel>
                        <TextBlock Text="IMVU" Foreground="#A0B0FF" FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center" DockPanel.Dock="Left" Margin="0,0,8,0"/>
                        <TextBlock x:Name="PageUrlText" Text="Loading…" Foreground="#8080A8" FontSize="10"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <Button Content="Home" Style="{StaticResource Win11ButtonSmall}" Click="NavHome_Click" Margin="0,0,4,0"/>
                            <Button Content="Chat" Style="{StaticResource Win11ButtonSmall}" Click="NavChat_Click" Margin="0,0,4,0"/>
                            <Button Content="Reload" Style="{StaticResource Win11ButtonSmall}" Click="NavReload_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <TextBlock DockPanel.Dock="Top" Text="Log in and open your chat room here, then Start Bot →"
                           Foreground="#606080" FontSize="9" Margin="2,0,0,4"/>
                <wv2:WebView2 x:Name="ImvuWebView" />
            </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                      Background="#2A2A45" ShowsPreview="True"/>

        <!-- Right: bot panel -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition x:Name="ActivityLogRow" Height="180" MinHeight="72"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header + main controls -->
            <Border Grid.Row="0" Background="#252540" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                <StackPanel>
                    <DockPanel LastChildFill="True" Margin="0,0,0,4">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="UpdateBtn" Content="v0.9.0 - Up To Date" Style="{StaticResource Win11BotToggleButton}"
                                    Click="UpdateBtn_Click" Margin="0,0,6,0" VerticalAlignment="Center"
                                    Padding="10,4" FontSize="10" MinWidth="0"/>
                            <Button x:Name="ExitBtn" Content="Exit" Style="{StaticResource Win11ButtonSmall}"
                                    Click="ExitButton_Click" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="IMVU Companion" Foreground="#E8E8FF" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock x:Name="StatusText" Text="Loading IMVU…" Foreground="#A0A0C8" FontSize="10"
                               Margin="0,0,0,6" TextWrapping="Wrap"/>
                    <WrapPanel>
                        <Button x:Name="BotToggleBtn" Content="Start Bot" Style="{StaticResource Win11BotToggleButton}"
                                Click="BotToggleBtn_Click" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <Button Content="Session Stats" Click="SessionStats_Click" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <ComboBox x:Name="AppLanguageCombo" Style="{StaticResource Win11ComboBoxButton}"
                                  Width="110" Height="28"
                                  SelectionChanged="AppLanguageCombo_SelectionChanged" VerticalAlignment="Center">
                            <ComboBoxItem Content="English" Tag="en"/>
                            <ComboBoxItem Content="Русский" Tag="ru"/>
                        </ComboBox>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Settings (scrollable) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,6">
                <StackPanel>
                    <Expander Header="Welcome Settings" IsExpanded="False" Margin="0,0,0,6"
                              Background="#1E1E32" Foreground="#E0E0FF">
                        <StackPanel Margin="4">
                            <!-- Line 1: delivery for 1st welcome -->
                            <ComboBox x:Name="Welcome1DeliveryCombo" Height="26" Margin="0,0,0,6"
                                      HorizontalAlignment="Left" MinWidth="120"
                                      SelectionChanged="Welcome1DeliveryCombo_SelectionChanged">
                                <ComboBoxItem Content="Public" Tag="public" IsSelected="True"/>
                                <ComboBoxItem Content="Whisper" Tag="whisper"/>
                            </ComboBox>

                            <!-- Line 2: 1st message list -->
                            <ListBox x:Name="Welcome1List" Height="72" Margin="0,0,0,6"
                                     SelectionChanged="Welcome1List_SelectionChanged"
                                     Background="#141428" Foreground="#C0C0E0" BorderBrush="#3A3A58"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     HorizontalContentAlignment="Stretch"/>

                            <!-- Line 3: edit + Add / Update / Delete -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="Welcome1EditBox" Grid.Column="0" Height="26" Margin="0,0,6,0"
                                         Background="#141428" Foreground="#E0E0FF" BorderBrush="#3A3A58"
                                         ToolTip="Use {name} for joiner name."/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Add" Click="Welcome1Add_Click" Margin="0,0,4,0"/>
                                    <Button Content="Update" Click="Welcome1Update_Click" Margin="0,0,4,0"/>
                                    <Button Content="Delete" Click="Welcome1Delete_Click"/>
                                </StackPanel>
                            </Grid>

                            <!-- Line 4: 2nd Msg enable + delivery -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <CheckBox x:Name="Welcome2EnabledCheck" Content="2nd Msg:"
                                          Foreground="#C0C0E0" VerticalAlignment="Center"
                                          Checked="Welcome2EnabledCheck_Changed"
                                          Unchecked="Welcome2EnabledCheck_Changed"/>
                                <ComboBox x:Name="Welcome2DeliveryCombo" Height="26" Margin="10,0,0,0"
                                          MinWidth="120" Visibility="Collapsed"
                                          SelectionChanged="Welcome2DeliveryCombo_SelectionChanged">
                                    <ComboBoxItem Content="Public" Tag="public"/>
                                    <ComboBoxItem Content="Whisper" Tag="whisper" IsSelected="True"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Lines 5–6: 2nd message list + editor (shown when checked) -->
                            <StackPanel x:Name="Welcome2Panel" Visibility="Collapsed">
                                <ListBox x:Name="Welcome2List" Height="72" Margin="0,0,0,6"
                                         SelectionChanged="Welcome2List_SelectionChanged"
                                         Background="#141428" Foreground="#C0C0E0" BorderBrush="#3A3A58"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         HorizontalContentAlignment="Stretch"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="Welcome2EditBox" Grid.Column="0" Height="26" Margin="0,0,6,0"
                                             Background="#141428" Foreground="#E0E0FF" BorderBrush="#3A3A58"
                                             ToolTip="Use {name} for joiner name."/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Add" Click="Welcome2Add_Click" Margin="0,0,4,0"/>
                                        <Button Content="Update" Click="Welcome2Update_Click" Margin="0,0,4,0"/>
                                        <Button Content="Delete" Click="Welcome2Delete_Click"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <TextBlock Text="Random pick per join; next pick avoids the previous message. Use {name}."
                                       FontSize="9" Foreground="#707090" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Expander>

                    <Expander Header="!Commands" IsExpanded="False" Margin="0,0,0,6"
                              Background="#1E1E32" Foreground="#E0E0FF">
                        <StackPanel Margin="4">
                            <WrapPanel Margin="0,0,0,4">
                                <ComboBox x:Name="CommandCategoryCombo" Width="120" Height="26" SelectionChanged="CommandCategoryCombo_SelectionChanged"/>
                                <Button Content="Add" Click="AddCommand_Click" Margin="6,0,0,0"/>
                                <Button Content="Delete" Click="RemoveCommand_Click" Margin="4,0,0,0"/>
                                <Button Content="Save" Click="SaveCommands_Click" Margin="4,0,0,0"/>
                            </WrapPanel>
                            <WrapPanel Margin="0,0,0,4">
                                <TextBlock Text="Category:" VerticalAlignment="Center" FontSize="10" Foreground="#A0A0C8" Margin="0,0,6,0"/>
                                <TextBox x:Name="CategoryNameEditBox" Width="120" Height="26" Background="#141428" Foreground="#E0E0FF" BorderBrush="#3A3A58"/>
                                <Button Content="Rename" Click="RenameCategory_Click" Margin="6,0,0,0"/>
                                <TextBox x:Name="NewCategoryTextBox" Width="90" Height="26" Margin="6,0,0,0" Background="#141428" Foreground="#E0E0FF" BorderBrush="#3A3A58"/>
                                <Button Content="+ Category" Click="AddCategory_Click" Margin="4,0,0,0"/>
                            </WrapPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="56" MinHeight="28"/>
                                    <RowDefinition Height="4"/>
                                </Grid.RowDefinitions>
                                <ListBox x:Name="CommandsList" Grid.Row="0"
                                         SelectionChanged="CommandsList_SelectionChanged"
                                         Background="#141428" Foreground="#C0C0E0" BorderBrush="#3A3A58"
                                         DisplayMemberPath="Display"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                                              Background="#2A2A45" ResizeDirection="Rows" ShowsPreview="True"/>
                            </Grid>
                            <WrapPanel Margin="0,6,0,0">
                                <TextBox x:Name="CommandEditBox" Width="80" Height="26" Background="#141428" Foreground="#E0E0FF" BorderBrush="#3A3A58"/>
                                <TextBox x:Name="CommandResponseEditBox" Width="170" Height="26" Margin="6,0,0,0" Background="#141428" Foreground="#E0E0FF" BorderBrush="#3A3A58"/>
                                <Button Content="Update" Click="UpdateCommand_Click" Margin="6,0,0,0"/>
                            </WrapPanel>
                        </StackPanel>
                    </Expander>

                    <Expander Header="AI Providers" IsExpanded="False" Margin="0,0,0,6"
                              Background="#1E1E32" Foreground="#E0E0FF">
                        <StackPanel Margin="4">
                            <TextBlock Text="Bot Display Name (your IMVU chat name — prevents echo loops):"
                                       FontSize="9" Foreground="#A0A0C8" Margin="0,0,0,2"/>
                            <TextBox x:Name="BotDisplayNameBox" Height="26" Margin="0,0,0,6"
                                     Background="#141428" Foreground="#E0E0FF" BorderBrush="#3A3A58"
                                     LostFocus="BotDisplayNameBox_LostFocus"
                                     ToolTip="Must match your IMVU name shown in chat (.cs2-name)"/>
                            <WrapPanel Margin="0,0,0,4">
                                <ComboBox x:Name="AiProviderCombo" Style="{StaticResource Win11ComboBoxButton}"
                                          Width="130" Height="26"
                                          SelectionChanged="AiProviderCombo_SelectionChanged"/>
                                <Button Content="Save" Click="SaveAiSettings_Click" Margin="8,0,0,0"/>
                            </WrapPanel>
                            <StackPanel x:Name="AiProviderFieldsPanel" Margin="0,2,0,0"/>
                            <TextBlock x:Name="AiProviderStatusText" FontSize="9" Foreground="#707090"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <TextBlock Text="!bbot triggers AI (maintenance reply until connected). Case-insensitive."
                                       FontSize="9" Foreground="#707090" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                          Background="#2A2A45" ResizeDirection="Rows" ShowsPreview="True"/>

            <!-- Activity log (resizable height) -->
            <DockPanel Grid.Row="3" LastChildFill="True" Margin="0,0,0,2">
                <TextBlock DockPanel.Dock="Top" Text="Activity Log" Foreground="#8080A8" FontSize="9" Margin="0,0,0,2"/>
                <Border Background="#141428" CornerRadius="4" BorderBrush="#2A2A45" BorderThickness="1">
                    <RichTextBox x:Name="LogBox" IsReadOnly="True" FontFamily="Consolas" FontSize="10"
                                 Background="Transparent" BorderThickness="0" Foreground="#C0C0E0"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"/>
                </Border>
            </DockPanel>

            <TextBlock Grid.Row="4" x:Name="AliveText" FontSize="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center" Margin="0" Padding="0"/>
        </Grid>
    </Grid>
</Window>